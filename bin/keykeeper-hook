#!/usr/bin/env python3
"""keykeeper-managed: forwards Claude Code, Cursor, Codex, and Gemini hook payloads to the
keykeeper GUI socket.

Most events are fire-and-forget — payload goes to ~/.claude/keykeeper.sock,
script half-closes, exits. Silent if the GUI isn't listening.

Claude `PermissionRequest` (bidirectional):
  Tagged with a request_id; script blocks waiting for the GUI to reply
  allow/deny, then writes Claude's hookSpecificOutput shape to stdout.
  Claude shows its terminal prompt concurrently — first to commit wins.

Cursor `beforeShellExecution` (observation + handoff):
  Empirically, Cursor's `allowlist` approvalMode treats hook
  `permission:"allow"` as advisory — the user must still confirm in
  Cursor's native inline UI. So we don't pretend keykeeper can
  pre-approve: the script returns `"ask"` immediately and lets Cursor's
  UI handle the decision. Visibility into the request still flows to
  keykeeper as a fire-and-forget event for the activity log.

All other Cursor hooks (sessionStart/sessionEnd/beforeSubmitPrompt/
preToolUse/postToolUse/afterAgentResponse/stop): pure fire-and-forget
to the bridge, which is the canonical observability channel for Cursor
since the SQLite poller was retired.

Gemini hooks are observation-only in this script. The command is invoked with
`--tool gemini`, forwards events to the bridge, and writes `{}` to stdout so
Gemini's hook runner treats the no-op as valid structured JSON. Gemini's
Notification/ToolPermission event is visibility-only; the actual decision
happens in Gemini's own UI.
"""
import json, os, socket, sys, uuid

SOCK = os.path.join(os.path.expanduser("~"), ".keykeeper", "keykeeper.sock")

QUICK_TIMEOUT_S = 2.0


def getenv_first(*names):
    for name in names:
        value = os.environ.get(name)
        if value:
            return value
    return None


def ensure_gemini_context(payload):
    # Gemini documents these fields on stdin, but also exposes them as
    # sanitized hook env vars. Backfill from env so Keykeeper can still
    # key an external session if a CLI build omits a field on a hook.
    if not payload.get("session_id"):
        payload["session_id"] = getenv_first(
            "GEMINI_SESSION_ID",
            "GEMINI_CLI_SESSION_ID",
        ) or "gemini-%s" % os.getppid()
    if not payload.get("cwd"):
        payload["cwd"] = getenv_first(
            "GEMINI_CWD",
            "GEMINI_PROJECT_DIR",
            "CLAUDE_PROJECT_DIR",
        ) or os.getcwd()


def emit_cursor_permission(permission, message=None):
    """Write Cursor's beforeShellExecution reply.
    permission must be 'allow' or 'deny'. message is shown both in the
    Cursor UI and sent back to the agent."""
    msg = str(message) if message else ("Approved via keykeeper." if permission == "allow" else "Denied via keykeeper.")
    out = {
        "permission": permission,
        "user_message": msg,
        "agent_message": msg,
    }
    sys.stdout.write(json.dumps(out))
    sys.stdout.flush()


def emit_claude_permission(behavior, message=None):
    """Write Claude Code's PermissionRequest hookSpecificOutput.
    behavior must be 'allow' or 'deny'. message is the deny reason
    shown to Claude (decision.message); ignored for allow per upstream
    contract."""
    decision = {"behavior": behavior}
    if behavior == "deny" and message:
        decision["message"] = str(message)
    out = {
        "hookSpecificOutput": {
            "hookEventName": "PermissionRequest",
            "decision": decision,
        }
    }
    sys.stdout.write(json.dumps(out))
    sys.stdout.flush()


def emit_noop():
    sys.stdout.write("{}")
    sys.stdout.flush()


def silent_exit():
    sys.exit(0)


def fire_and_forget(raw):
    """Send payload, half-close, exit — used for any event that doesn't
    need a reply (everything except Claude's PermissionRequest)."""
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(QUICK_TIMEOUT_S)
    s.connect(SOCK)
    s.sendall(raw)
    s.shutdown(socket.SHUT_WR)
    s.close()


def bidirectional_permission(payload):
    """Tag with request_id, send, block on recv until the bridge
    replies or closes the socket. Returns the parsed reply dict, or
    None if the GUI didn't answer.

    No client-side timeout — Claude's terminal prompt runs concurrently,
    and the hook stays alive until either the GUI clicks (we get a
    reply) or the user clicks in Claude's terminal (Claude SIGTERMs
    us)."""
    request_id = str(uuid.uuid4())
    payload["__kh_permission_request_id"] = request_id

    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.connect(SOCK)
    s.sendall(json.dumps(payload).encode("utf-8"))
    s.shutdown(socket.SHUT_WR)

    chunks = []
    try:
        while True:
            buf = s.recv(4096)
            if not buf:
                break
            chunks.append(buf)
    finally:
        try:
            s.close()
        except Exception:
            pass

    if not chunks:
        return None

    try:
        return json.loads(b"".join(chunks).decode("utf-8"))
    except Exception:
        return None


def main():
    # Optional --tool flag tags payloads with __kh_tool so the bridge
    # can attribute events to the right wielder when multiple CLIs
    # share Claude-shaped payload format (Codex uses the same shape),
    # or PascalCase event names (Gemini).
    tool_marker = None
    argv = sys.argv[1:]
    for i, a in enumerate(argv):
        if a == "--tool" and i + 1 < len(argv):
            tool_marker = argv[i + 1]
            break
    is_gemini = tool_marker == "gemini"

    if not os.path.exists(SOCK):
        if is_gemini:
            emit_noop()
        silent_exit()

    try:
        raw = sys.stdin.buffer.read()
        if not raw:
            if is_gemini:
                emit_noop()
            silent_exit()

        try:
            payload = json.loads(raw.decode("utf-8"))
        except Exception:
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            if is_gemini:
                emit_noop()
            silent_exit()

        if is_gemini:
            ensure_gemini_context(payload)

        if tool_marker:
            payload["__kh_tool"] = tool_marker
            raw = json.dumps(payload).encode("utf-8")

        event_name = payload.get("hook_event_name")

        # Claude permission request — bidirectional, blocks for GUI.
        if event_name == "PermissionRequest" and not is_gemini:
            reply = bidirectional_permission(payload)
            if reply:
                decision = reply.get("permissionDecision")
                if decision in ("allow", "deny"):
                    emit_claude_permission(decision, reply.get("denyMessage"))
            silent_exit()

        # Gemini ToolPermission notification — observational. Tag with a
        # request id so keykeeper can render an acknowledgement letter, but
        # return `{}` immediately because Gemini's Notification hook cannot
        # grant or deny the tool.
        if is_gemini and event_name == "Notification" and payload.get("notification_type") == "ToolPermission":
            try:
                request_id = str(uuid.uuid4())
                payload["__kh_permission_request_id"] = request_id
                fire_and_forget(json.dumps(payload).encode("utf-8"))
            except Exception:
                pass
            emit_noop()
            silent_exit()

        # Cursor permission gate — observational. We tag the payload
        # with a request_id so the bridge creates a permission_request
        # event (and the renderer pops a letter for visibility), then
        # immediately return "ask" so Cursor's native UI handles the
        # actual decision. The bridge's `close` handler drops the
        # pending entry as soon as we close the socket — letter is
        # informational, no allow/deny path expected to work.
        if event_name == "beforeShellExecution":
            try:
                request_id = str(uuid.uuid4())
                payload["__kh_permission_request_id"] = request_id
                s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
                s.settimeout(QUICK_TIMEOUT_S)
                s.connect(SOCK)
                s.sendall(json.dumps(payload).encode("utf-8"))
                s.shutdown(socket.SHUT_WR)
                s.close()
            except Exception:
                pass
            sys.stdout.write(json.dumps({"permission": "ask"}))
            sys.stdout.flush()
            silent_exit()

        # Cursor `beforeSubmitPrompt` requires an explicit
        # `{"continue": true}` for the prompt to proceed unmodified.
        # Without it, Cursor's behavior is undefined — empirically
        # results in the prompt bubble being rendered twice.
        if event_name == "beforeSubmitPrompt":
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            sys.stdout.write(json.dumps({"continue": True}))
            sys.stdout.flush()
            silent_exit()

        # Cursor `preToolUse` requires `{permission: "allow"|"deny"}`.
        # Emit "allow" so the tool proceeds unmodified; in allowlist
        # mode this is advisory (Cursor still gates per its policy).
        if event_name == "preToolUse":
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            sys.stdout.write(json.dumps({"permission": "allow"}))
            sys.stdout.flush()
            silent_exit()

        # All other events (Claude PreToolUse/PostToolUse/etc., Cursor
        # sessionStart/sessionEnd/stop/postToolUse/afterAgentResponse,
        # Gemini SessionStart/BeforeAgent/BeforeTool/etc.):
        # pure fire-and-forget to the bridge for activity-log emission.
        # Gemini expects structured JSON on stdout even for no-op hooks.
        fire_and_forget(raw)
        if is_gemini:
            emit_noop()
    except Exception:
        # Never fail a hook — we don't want to break the upstream.
        if tool_marker == "gemini":
            try:
                emit_noop()
            except Exception:
                pass
        pass


if __name__ == "__main__":
    main()
