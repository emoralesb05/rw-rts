#!/usr/bin/env python3
"""kh-rts-managed: forwards Claude Code hook payloads to the kh-rts GUI socket.

Most events are fire-and-forget — payload goes to ~/.claude/kh-rts.sock,
script half-closes, exits. Silent if the GUI isn't listening.

Phase 2B #18 (permission approval) uses Claude Code's `PermissionRequest`
hook event, which fires only when Claude is about to show its permission
dialog. That's exactly when keykeeper should also ask. The script:

  1. Tags the payload with a request_id so the GUI can route a reply back.
  2. Sends payload, half-closes, waits for the GUI's allow/deny.
  3. Writes Claude Code's expected hookSpecificOutput format to stdout
     (decision.behavior — distinct from PreToolUse's permissionDecision).
  4. Returning "allow" SKIPS Claude's terminal prompt entirely. Returning
     "deny" blocks the tool call.
  5. Silent exit on timeout / no GUI / socket error → Claude falls back
     to its own permission prompt. Default-safe.

Earlier iterations tried PreToolUse + risky-pattern detection. That ran
too eagerly (every PreToolUse) and double-confirmed (Claude's prompt
and keykeeper letter both showed). PermissionRequest fires only when
needed, so no risky detection or false-positive suppression.
"""
import json, os, socket, sys, uuid

SOCK = os.path.join(os.path.expanduser("~"), ".claude", "kh-rts.sock")

# Permission requests block until the user decides — no client-side
# timeout. If the GUI dies, the socket drops and recv() returns EOF
# immediately, so Claude falls back to its own prompt cleanly. We
# previously had a 60s ceiling, but the user explicitly preferred to
# wait indefinitely rather than risk an auto-dismiss before they could
# read and decide.
QUICK_TIMEOUT_S = 2.0


def emit_permission_decision(behavior, message=None):
    """Write Claude Code's PermissionRequest hookSpecificOutput.
    behavior must be 'allow' or 'deny'. message is the deny reason
    shown to Claude (decision.message); ignored for allow per upstream
    contract."""
    decision = {"behavior": behavior}
    if behavior == "deny" and message:
        decision["message"] = str(message)
    out = {
        "hookSpecificOutput": {
            "hookEventName": "PermissionRequest",
            "decision": decision,
        }
    }
    sys.stdout.write(json.dumps(out))
    sys.stdout.flush()


def silent_exit():
    sys.exit(0)


def fire_and_forget(raw):
    """Original behavior — send payload, half-close, exit."""
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(QUICK_TIMEOUT_S)
    s.connect(SOCK)
    s.sendall(raw)
    s.shutdown(socket.SHUT_WR)
    s.close()


def bidirectional_permission(payload):
    """Tag with request_id, send, wait for GUI reply, emit decision."""
    request_id = str(uuid.uuid4())
    payload["__kh_permission_request_id"] = request_id

    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    # No timeout: blocks until the bridge writes a reply or closes the
    # socket. Socket close (EOF) returns us empty chunks → fall through
    # to silent exit, so Claude falls back to its terminal prompt.
    s.connect(SOCK)
    s.sendall(json.dumps(payload).encode("utf-8"))
    s.shutdown(socket.SHUT_WR)

    chunks = []
    try:
        while True:
            buf = s.recv(4096)
            if not buf:
                break
            chunks.append(buf)
    finally:
        s.close()

    if not chunks:
        return  # silent exit caller-side

    try:
        reply = json.loads(b"".join(chunks).decode("utf-8"))
        # Bridge replies with {"permissionDecision": "allow"|"deny",
        # "denyMessage": "..."?} — translate to PermissionRequest's
        # expected hookSpecificOutput shape. denyMessage only flows
        # through on deny (allow has no message field upstream).
        decision = reply.get("permissionDecision")
        deny_message = reply.get("denyMessage")
        if decision in ("allow", "deny"):
            emit_permission_decision(decision, deny_message)
    except Exception:
        pass


def main():
    if not os.path.exists(SOCK):
        silent_exit()

    try:
        raw = sys.stdin.buffer.read()
        if not raw:
            silent_exit()

        try:
            payload = json.loads(raw.decode("utf-8"))
        except Exception:
            # Malformed payload — best-effort forward, exit.
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            silent_exit()

        event_name = payload.get("hook_event_name")

        if event_name == "PermissionRequest":
            bidirectional_permission(payload)
            silent_exit()

        # All other events: fire-and-forget.
        fire_and_forget(raw)
    except Exception:
        # Never fail a hook — we don't want to break claude.
        pass


if __name__ == "__main__":
    main()
