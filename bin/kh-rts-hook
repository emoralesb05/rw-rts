#!/usr/bin/env python3
"""kh-rts-managed: forwards Claude Code AND Cursor hook payloads to the
kh-rts GUI socket.

Most events are fire-and-forget — payload goes to ~/.claude/kh-rts.sock,
script half-closes, exits. Silent if the GUI isn't listening.

Claude `PermissionRequest` (bidirectional):
  Tagged with a request_id; script blocks waiting for the GUI to reply
  allow/deny, then writes Claude's hookSpecificOutput shape to stdout.
  Claude shows its terminal prompt concurrently — first to commit wins.

Cursor `beforeShellExecution` (observation + handoff):
  Empirically, Cursor's `allowlist` approvalMode treats hook
  `permission:"allow"` as advisory — the user must still confirm in
  Cursor's native inline UI. So we don't pretend keykeeper can
  pre-approve: the script returns `"ask"` immediately and lets Cursor's
  UI handle the decision. Visibility into the request still flows to
  keykeeper as a fire-and-forget event for the activity log.

All other Cursor hooks (sessionStart/sessionEnd/beforeSubmitPrompt/
preToolUse/postToolUse/afterAgentResponse/stop): pure fire-and-forget
to the bridge, which is the canonical observability channel for Cursor
since the SQLite poller was retired.
"""
import json, os, socket, sys, uuid

SOCK = os.path.join(os.path.expanduser("~"), ".claude", "kh-rts.sock")

QUICK_TIMEOUT_S = 2.0


def emit_claude_permission(behavior, message=None):
    """Write Claude Code's PermissionRequest hookSpecificOutput.
    behavior must be 'allow' or 'deny'. message is the deny reason
    shown to Claude (decision.message); ignored for allow per upstream
    contract."""
    decision = {"behavior": behavior}
    if behavior == "deny" and message:
        decision["message"] = str(message)
    out = {
        "hookSpecificOutput": {
            "hookEventName": "PermissionRequest",
            "decision": decision,
        }
    }
    sys.stdout.write(json.dumps(out))
    sys.stdout.flush()


def silent_exit():
    sys.exit(0)


def fire_and_forget(raw):
    """Send payload, half-close, exit — used for any event that doesn't
    need a reply (everything except Claude's PermissionRequest)."""
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(QUICK_TIMEOUT_S)
    s.connect(SOCK)
    s.sendall(raw)
    s.shutdown(socket.SHUT_WR)
    s.close()


def bidirectional_permission(payload):
    """Tag with request_id, send, block on recv until the bridge
    replies or closes the socket. Returns the parsed reply dict, or
    None if the GUI didn't answer.

    No client-side timeout — Claude's terminal prompt runs concurrently,
    and the hook stays alive until either the GUI clicks (we get a
    reply) or the user clicks in Claude's terminal (Claude SIGTERMs
    us)."""
    request_id = str(uuid.uuid4())
    payload["__kh_permission_request_id"] = request_id

    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.connect(SOCK)
    s.sendall(json.dumps(payload).encode("utf-8"))
    s.shutdown(socket.SHUT_WR)

    chunks = []
    try:
        while True:
            buf = s.recv(4096)
            if not buf:
                break
            chunks.append(buf)
    finally:
        try:
            s.close()
        except Exception:
            pass

    if not chunks:
        return None

    try:
        return json.loads(b"".join(chunks).decode("utf-8"))
    except Exception:
        return None


def main():
    if not os.path.exists(SOCK):
        silent_exit()

    try:
        raw = sys.stdin.buffer.read()
        if not raw:
            silent_exit()

        try:
            payload = json.loads(raw.decode("utf-8"))
        except Exception:
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            silent_exit()

        event_name = payload.get("hook_event_name")

        # Claude permission request — bidirectional, blocks for GUI.
        if event_name == "PermissionRequest":
            reply = bidirectional_permission(payload)
            if reply:
                decision = reply.get("permissionDecision")
                if decision in ("allow", "deny"):
                    emit_claude_permission(decision, reply.get("denyMessage"))
            silent_exit()

        # Cursor permission gate — return "ask" immediately so Cursor's
        # native UI takes over (keykeeper can't pre-approve in allowlist
        # mode anyway). Notify keykeeper fire-and-forget for visibility.
        if event_name == "beforeShellExecution":
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            sys.stdout.write(json.dumps({"permission": "ask"}))
            sys.stdout.flush()
            silent_exit()

        # Cursor `beforeSubmitPrompt` requires an explicit
        # `{"continue": true}` for the prompt to proceed unmodified.
        # Without it, Cursor's behavior is undefined — empirically
        # results in the prompt bubble being rendered twice.
        if event_name == "beforeSubmitPrompt":
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            sys.stdout.write(json.dumps({"continue": True}))
            sys.stdout.flush()
            silent_exit()

        # Cursor `preToolUse` requires `{permission: "allow"|"deny"}`.
        # Emit "allow" so the tool proceeds unmodified; in allowlist
        # mode this is advisory (Cursor still gates per its policy).
        if event_name == "preToolUse":
            try:
                fire_and_forget(raw)
            except Exception:
                pass
            sys.stdout.write(json.dumps({"permission": "allow"}))
            sys.stdout.flush()
            silent_exit()

        # All other events (Claude PreToolUse/PostToolUse/etc., Cursor
        # sessionStart/sessionEnd/stop/postToolUse/afterAgentResponse):
        # pure fire-and-forget to the bridge for activity-log emission.
        # No stdout output — these events are observational on Cursor's
        # side ("the response is logged but not used").
        fire_and_forget(raw)
    except Exception:
        # Never fail a hook — we don't want to break the upstream.
        pass


if __name__ == "__main__":
    main()
